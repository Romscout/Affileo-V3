# Copie ce fichier en .env.local et remplis les valeurs.
# .env.local n'est jamais commité (ignoré par git).

# Meta Pixel ID — obtenu dans Meta Business Manager → Events Manager
NEXT_PUBLIC_META_PIXEL_ID=

# Pseudo Instagram cible (sans le @) pour les CTA "DM Insta"
NEXT_PUBLIC_INSTAGRAM_HANDLE=affileo

# Plausible domain (optionnel) si on utilise Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
